{
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/india.svg", "dest": "/india.svg" },
    { "src": "/login(.*)", "dest": "/login.html" },
    { "src": "/dashboard(.*)", "dest": "/dashboard.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
